{
  "name": "arbor-florest-monitoring",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node -e \"const fs=require('fs'); if (fs.existsSync('.next')) fs.rmSync('.next',{recursive:true,force:true});\" && next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.5",
    "axios": "^1.12.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "leaflet": "^1.9.4",
    "msw": "^2.11.5",
    "next": "16.2.3",
    "react-hook-form": "^7.65.0",
    "react-leaflet": "^5.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.2.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.5",
    "prettier": "^3.6.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
